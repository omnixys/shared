{
  "name": "@omnixys/shared",
  "version": "1.0.0",
  "type": "module",
  "private": false,
  "packageManager": "pnpm@10.33.0",
  "description": "Shared utilities and types for Omnixys microservices",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "format": "prettier --cache --write \"src/**/*.{ts,js,json,prisma,md,yaml}\"",
    "clean": "rimraf dist",
    "build:tsup": "tsup src/index.ts --format esm,cjs --dts",
    "patch": "pnpm version patch",
    "release": "semantic-release",
    "dev": "tsc -w"
  },
  "keywords": [
    "omnixys",
    "shared",
    "utilities",
    "types",
    "nestjs",
    "microservices"
  ],
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "@commitlint/config-conventional": "^20.4.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@swc/core": "^1.15.21",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-sort-imports": "^1.8.11",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1"
  },
  "dependencies": {
    "dataloader": "^2.2.3",
    "jose": "^6.2.1"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0"
  }
}
